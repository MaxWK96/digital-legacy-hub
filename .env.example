# Copy this file to .env and fill in your values.

# Sepolia RPC URL (Alchemy recommended)
NEXT_PUBLIC_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/weUBYd5HWeZ4oafCRHiUR

# Deployer / owner private key (DO NOT commit)
PRIVATE_KEY=7c371aaab1211b0c398f78d4566b77ac08901e85b368ebed9a184a468009dd9f

# LifeContract address (set after running: npm run contracts:deploy)
LIFE_CONTRACT_ADDRESS=0x...
VITE_LIFE_CONTRACT_ADDRESS=0x...

# VerdictRegistry (already deployed, don't change)
VERDICT_REGISTRY_ADDRESS=0x7576b99366a945BB29A087cA9bA467d28397288f

# World ID (staging app for hackathon)
NEXT_PUBLIC_WORLD_APP_ID=app_staging_test
VITE_WORLD_APP_ID=app_staging_test

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=...

# Optional: OpenWeather API key (for future proof-of-life signals)
OPENWEATHER_API_KEY=...
